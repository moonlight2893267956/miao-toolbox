# ===========================================
# 阿渺工具箱 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env

# ---------- Nacos 配置中心 (epic-nacos-config, story-n1) ----------
# Nacos Server 地址（服务端口，供应用 OpenAPI 拉取配置）
NACOS_ADDR=nacos.yunmiao.site:38848
# Nacos 控制台 UI 端口（仅人工访问，应用不直接连接）：nacos.yunmiao.site:38848
# 命名空间（架构定义 Namespace=miao-toolbox）
NACOS_NAMESPACE=miao-toolbox-dev
# 访问凭据（生产由 miao-infra 注入；启用了 NACOS_AUTH，默认 nacos/nacos 仅本地 fallback）
NACOS_USERNAME=nacos
NACOS_PASSWORD=your-nacos-password

# ---------- 数据库 ----------
MYSQL_URL=jdbc:mysql://localhost:3306/miao_toolbox?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=UTC
MYSQL_DATABASE=miao_toolbox
MYSQL_USER=miao
MYSQL_PASSWORD=miao_dev

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=miao_redis_dev

# ---------- JWT ----------
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long-change-this-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-at-least-256-bits-change-this-in-production
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ---------- GitHub OAuth ----------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://tools.yunmiao.site/api/auth/oauth/github/callback
GITHUB_FRONTEND_CALLBACK_URL=https://tools.yunmiao.site/oauth/callback

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://tools.yunmiao.site/api/auth/oauth/google/callback
GOOGLE_FRONTEND_CALLBACK_URL=https://tools.yunmiao.site/oauth/callback

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------- 腾讯云 COS ----------
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-cos-bucket-name
COS_REGION=ap-beijing

# ---------- miao-ai Agent: diff-explainer (文本对比分析) ----------
MIAO_AI_AGENT_DIFF_ENABLED=true
MIAO_AI_AGENT_DIFF_BASE_URL=http://miao-backend:8000
MIAO_AI_AGENT_DIFF_NAME=diff-explainer
MIAO_AI_AGENT_DIFF_API_KEY=
MIAO_AI_AGENT_DIFF_CONNECT_TIMEOUT=5000
MIAO_AI_AGENT_DIFF_READ_TIMEOUT=60000
MIAO_AI_AGENT_DIFF_RETRY_COUNT=2
MIAO_AI_AGENT_DIFF_RETRY_INTERVAL=1000

# ---------- miao-ai Agent: json-repairer (JSON 格式修复) ----------
MIAO_AI_AGENT_JSON_REPAIR_ENABLED=true
MIAO_AI_AGENT_JSON_REPAIR_BASE_URL=http://miao-backend:8000
MIAO_AI_AGENT_JSON_REPAIR_NAME=json-repairer
MIAO_AI_AGENT_JSON_REPAIR_API_KEY=
MIAO_AI_AGENT_JSON_REPAIR_CONNECT_TIMEOUT=5000
MIAO_AI_AGENT_JSON_REPAIR_READ_TIMEOUT=300000
MIAO_AI_AGENT_JSON_REPAIR_RETRY_COUNT=2
MIAO_AI_AGENT_JSON_REPAIR_RETRY_INTERVAL=1000

# ---------- miao-ai Agent: translate-agent (AI 增强翻译, FR-16, story-4.1) ----------
MIAO_AI_AGENT_TRANSLATE_ENABLED=true
MIAO_AI_AGENT_TRANSLATE_BASE_URL=http://miao-backend:8000
MIAO_AI_AGENT_TRANSLATE_NAME=translate-agent
MIAO_AI_AGENT_TRANSLATE_API_KEY=
MIAO_AI_AGENT_TRANSLATE_CONNECT_TIMEOUT=5000
MIAO_AI_AGENT_TRANSLATE_READ_TIMEOUT=120000
MIAO_AI_AGENT_TRANSLATE_RETRY_COUNT=2
MIAO_AI_AGENT_TRANSLATE_RETRY_INTERVAL=1000

# ---------- AI 输入限制 ----------
MIAO_AI_MAX_INPUT_BYTES=20480

# ---------- 百度翻译 (智能翻译工具, FR-20) ----------
BAIDU_TRANSLATE_ENABLED=false
BAIDU_APPID=your-baidu-appid
BAIDU_SECRET=your-baidu-secret
BAIDU_TRANSLATE_URL=https://fanyi-api.baidu.com/api/trans/vip/translate
BAIDU_DETECT_URL=https://fanyi-api.baidu.com/langid/v1/detect
BAIDU_IMAGE_URL=https://fanyi-api.baidu.com/api/trans/sdk/picture
BAIDU_CONNECT_TIMEOUT=5000
BAIDU_READ_TIMEOUT=60000
BAIDU_MAX_CONCURRENCY=10

# ---------- 百度语音翻译 (FR-12, story-3.1) ----------
# 以下两项均可省略：
#   BAIDU_VOICE_URL 省略时使用代码内置默认值，无需修改。
#   BAIDU_VOICE_SECRET_KEY 省略时自动复用上方 BAIDU_SECRET
#   （多数账号「语音翻译」与通用/图片翻译使用同一密钥）；
#   仅当百度后台「语音翻译」使用独立 secretKey 时在此单独填写。
# BAIDU_VOICE_URL=
# BAIDU_VOICE_SECRET_KEY=
