# ===========================================
# 阿渺工具箱 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ---------- 数据库 ----------
MYSQL_URL=jdbc:mysql://localhost:3306/miao_toolbox?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=UTC
MYSQL_USER=miao
MYSQL_PASSWORD=miao_dev
MYSQL_ROOT_PASSWORD=root_password

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT ----------
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long-change-this-in-production
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ---------- GitHub OAuth ----------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/oauth/github/callback
GITHUB_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/callback

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------- AI API Keys (占位) ----------
AI_API_KEYS=placeholder
