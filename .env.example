# ===========================================
# 阿渺工具箱 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# 本地开发用:本文件作为完整配置源(.env 加载后,spring boot 直接读)
# 生产部署用:docker-compose.prod.yml 只读其中部分变量,其余在 compose 里硬编码
#
# ⚠️ MySQL/Redis 由外部项目 miao-infra 提供(miao-infra 启动时自己生成 MYSQL_*/REDIS_*):
#   - 生产部署时,本文件的 MYSQL_USER / MYSQL_PASSWORD / REDIS_PASSWORD
#     必须与 miao-infra 服务器上的 .env 保持一致(在同一台服务器通常直接 scp 同一份)
#   - MYSQL_ROOT_PASSWORD 已迁出,改由 miao-infra 自己管理
#   - 容器名固定: miao-mysql / miao-redis(由 miao-infra compose 定义)
#   - 跨 compose 网络: miao-infra-net(external,本项目 compose 引用)
#
# 生产用到的关键变量:
#   JWT_SECRET / JWT_REFRESH_SECRET / CORS_ALLOWED_ORIGINS
#   MYSQL_USER / MYSQL_PASSWORD / REDIS_PASSWORD(与 miao-infra .env 同步)
#   MYSQL_DATABASE(默认 miao_toolbox,本项目业务库)
#   GITHUB_* / GOOGLE_* / COS_* (可选)

# ---------- 数据库 ----------
# 注意:生产部署时 MYSQL_URL 会被 docker-compose.prod.yml 覆盖为 miao-mysql:3306
MYSQL_URL=jdbc:mysql://localhost:3306/miao_toolbox?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=UTC
MYSQL_DATABASE=miao_toolbox
MYSQL_USER=miao
MYSQL_PASSWORD=miao_dev
# MYSQL_ROOT_PASSWORD 已迁至 miao-infra,本项目不需要 root 账号

# ---------- Redis ----------
# 注意:生产部署时 REDIS_HOST 会被 docker-compose.prod.yml 覆盖为 miao-redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=miao_redis_dev

# ---------- JWT ----------
# 必须 >= 256 bits,生产用 openssl rand -base64 64 生成
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long-change-this-in-production
# 单独配置 refresh token 签名密钥,生产必须独立于 access token
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-at-least-256-bits-change-this-in-production
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ---------- GitHub OAuth ----------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://tools.yunmiao.site/api/auth/oauth/github/callback
GITHUB_FRONTEND_CALLBACK_URL=https://tools.yunmiao.site/oauth/callback

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://tools.yunmiao.site/api/auth/oauth/google/callback
GOOGLE_FRONTEND_CALLBACK_URL=https://tools.yunmiao.site/oauth/callback

# ---------- CORS ----------
# 多个 origin 用逗号分隔
# 生产:https://tools.yunmiao.site
# 开发:http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------- 腾讯云 COS (文本对照文件上传) ----------
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-cos-bucket-name
COS_REGION=ap-beijing

# ---------- miao-ai Agent 平台 (AI 文本对比分析) ----------
# 启用后,前端"AI 变更分析"按钮可用
MIAO_AI_ENABLED=false
MIAO_AI_BASE_URL=http://miao-backend:8000
MIAO_AI_API_KEY=
MIAO_AI_AGENT_NAME=diff-explainer
MIAO_AI_CONNECT_TIMEOUT=5000
MIAO_AI_READ_TIMEOUT=60000
