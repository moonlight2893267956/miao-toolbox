# ===========================================
# 阿渺工具箱 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# 本地开发用:本文件作为完整配置源(.env 加载后,spring boot 直接读)
# 生产部署用:docker-compose.prod.yml 只读其中部分变量,其余在 compose 里硬编码
#   生产用到的关键变量:JWT_SECRET / JWT_REFRESH_SECRET / CORS_ALLOWED_ORIGINS
#                    MYSQL_ROOT_PASSWORD / MYSQL_USER / MYSQL_PASSWORD
#                    REDIS_PASSWORD
#                    GITHUB_* / GOOGLE_* / COS_* (可选)

# ---------- 数据库 ----------
# 注意:生产部署时 MYSQL_URL 会被 docker-compose.prod.yml 覆盖为 mysql:3306
MYSQL_URL=jdbc:mysql://localhost:3306/miao_toolbox?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=UTC
MYSQL_DATABASE=miao_toolbox
MYSQL_USER=miao
MYSQL_PASSWORD=miao_dev
MYSQL_ROOT_PASSWORD=root_password

# ---------- Redis ----------
# 注意:生产部署时 REDIS_HOST 会被 docker-compose.prod.yml 覆盖为 redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=miao_redis_dev

# ---------- JWT ----------
# 必须 >= 256 bits,生产用 openssl rand -base64 64 生成
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long-change-this-in-production
# 单独配置 refresh token 签名密钥,生产必须独立于 access token
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-at-least-256-bits-change-this-in-production
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ---------- GitHub OAuth ----------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/oauth/github/callback
GITHUB_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/callback

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/google/callback
GOOGLE_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth/callback

# ---------- CORS ----------
# 多个 origin 用逗号分隔
# 生产:https://tools.yunmiao.site
# 开发:http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------- 腾讯云 COS (文本对照文件上传) ----------
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-cos-bucket-name
COS_REGION=ap-guangzhou
