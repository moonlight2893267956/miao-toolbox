# ============================================================
# 本地开发密钥模板 — 复制为 application-local.yml 并填入真实值
# cp application-local.yml.example application-local.yml
# ============================================================

miao:
  jwt:
    secret: your-jwt-secret-key-at-least-256-bits-long
    refresh-secret: your-jwt-refresh-secret-key-at-least-256-bits-long
  oauth:
    github:
      client-id: your-github-client-id
      client-secret: your-github-client-secret
    google:
      client-id: your-google-client-id
      client-secret: your-google-client-secret
  cos:
    secret-id: your-cos-secret-id
    secret-key: your-cos-secret-key
    bucket: your-cos-bucket-name
  ai:
    agents:
      diff-explainer:
        enabled: true
        base-url: http://localhost:8000
        api-key: your-diff-explainer-api-key
      json-repairer:
        enabled: true
        base-url: http://localhost:8000
        api-key: your-json-repairer-api-key
